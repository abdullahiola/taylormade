# ══════════════════════════════════════════════════════
#   TaylorMade — Environment Variables Template
#   Replace ALL placeholder values with your real ones.
#   NEVER commit a file with real secrets to Git.
# ══════════════════════════════════════════════════════

# ── BACKEND  (copy to: backend/.env on your VPS) ──────

TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
SMTP_EMAIL=your_gmail_address@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here
JWT_SECRET=change-this-to-a-long-random-string
FRONTEND_URL=http://YOUR_VPS_IP

# DATABASE_URL=sqlite:////data/taylormade.db


# ── FRONTEND  (Vercel → Project Settings → Environment Variables) ─────────────

NEXT_PUBLIC_API_URL=/api/proxy
BACKEND_URL=http://YOUR_VPS_IP


# ── LOCAL DEV  (.env.local) ───────────────────────────

# NEXT_PUBLIC_API_URL=http://localhost:8000
